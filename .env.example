# PolyBTC Momentum — local environment template
#
# Copy to .env (gitignored) or point POLYBTC_ENV_FILE at your trading stack .env.
# Never commit real keys, private keys, wallet mnemonics, or API tokens.
#
# Two layers:
#   1) POLYBTC_*  — this skill (paths, profile, paper tools)
#   2) PM_*       — Polymarket live CLOB auth (usually only in the trading repo .env)

# ---------------------------------------------------------------------------
# Skill paths & process
# ---------------------------------------------------------------------------

# Polymarket execution stack (wrappers source .env from here by default).
POLYBTC_REPO=../pm-hl-conservative-plus-repo

# Explicit auth/env file for polybtc_ctl.sh (default: $POLYBTC_REPO/.env).
# POLYBTC_ENV_FILE=../pm-hl-conservative-plus-repo/.env

# Runtime output: paper/live logs, daily summaries, live_obs JSONL/CSV.
POLYBTC_RUNTIME_DIR=./runtime

# Optional Python binary (ctl / watcher / daily cron). Else: trading venv → skill venv → python3.
# POLYBTC_PY=/path/to/.venv/bin/python

# Optional override of the session runner entry script.
# POLYBTC_RUNNER=./scripts/test_polybtc_session_exit_sl.py

# ---------------------------------------------------------------------------
# Strategy / tooling defaults
# ---------------------------------------------------------------------------

# Default profile for cron/helpers.
# Live money: conservative | aggressive | high_confidence
# Research/logger only (NOT live money): observe
POLYBTC_PROFILE=conservative

# Equity baseline for guardrails / daily summary loss-cap context (USD).
POLYBTC_EQUITY=200

# Optional webhook for daily summary (Slack / Discord / Telegram-compatible).
# POLYBTC_WEBHOOK=https://hooks.example.com/...

# Optional: force previous calendar day for daily summary (YYYY-MM-DD, UTC).
# POLYBTC_DATE=2026-07-11

# Watcher: set to 1 to allow live path (still requires explicit --live on the CLI).
# POLYBTC_LIVE=0

# ---------------------------------------------------------------------------
# Live CLOB credentials (DO NOT put real values in a committed file)
# Usually live only in POLYBTC_ENV_FILE / trading-repo .env, sourced by ctl.
# Required by the live session runner for real order placement.
# ---------------------------------------------------------------------------

# PM_PRIVATE_KEY=
# PM_FUNDER=
# PM_ADDRESS=
# PM_SIGNATURE_TYPE=2
# PM_API_KEY=
# PM_API_SECRET=
# PM_API_PASSPHRASE=

# ---------------------------------------------------------------------------
# Optional open/close execution overrides
# If unset, the runner sets sensible defaults from the active profile:
#   PM_MAX_SPREAD, PM_MIN_TOP_ASK_NOTIONAL_USD, PM_ORDER_TYPE=FAK
# Close path may set PM_CLOSE_ORDER_TYPE (FAK / GTC).
# ---------------------------------------------------------------------------

# PM_MAX_SPREAD=0.03
# PM_MIN_TOP_ASK_NOTIONAL_USD=30
# PM_ORDER_TYPE=FAK
# PM_CLOSE_ORDER_TYPE=FAK
