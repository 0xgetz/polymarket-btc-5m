# PolyBTC Momentum local environment template
# Copy to .env or point POLYBTC_ENV_FILE to your existing trading env file.
# Never commit real keys, private keys, wallet mnemonics, or API tokens.

# Path to the Polymarket execution stack used by wrapper scripts.
POLYBTC_REPO=../pm-hl-conservative-plus-repo

# Runtime output directory for paper/live logs and daily summaries.
POLYBTC_RUNTIME_DIR=./runtime

# Default strategy profile: conservative or aggressive.
POLYBTC_PROFILE=conservative

# Equity baseline used by guardrail / summary helper tools.
POLYBTC_EQUITY=200

# Optional webhook URL for daily summary notifications.
# Supports Slack / Discord / Telegram-compatible webhook endpoints used by your wrapper.
POLYBTC_WEBHOOK=

# Optional runner override if your live execution script is outside this repo.
POLYBTC_RUNNER=
